# Comma-separated absolute paths to your music libraries (mounted into the
# container if using Docker).
HARMONIE_LIBRARIES=/music

# Where to store the SQLite database. In Docker, mount this dir as a volume
# so the index survives container restarts.
HARMONIE_DATA_DIR=/data

# Feature backend. "effnet" requires essentia-tensorflow (default).
# "musicextractor" runs without TensorFlow.
HARMONIE_BACKEND=effnet

# Number of analysis worker processes. Defaults to CPU count.
# HARMONIE_WORKERS=4

# Periodic scan interval in hours. 0 disables scheduled scans.
HARMONIE_SCAN_INTERVAL_HOURS=6

# Run a scan immediately on startup. Useful when bootstrapping.
HARMONIE_SCAN_ON_STARTUP=true

# HTTP server.
HARMONIE_HOST=0.0.0.0
HARMONIE_PORT=8842

# Optional API key. If set, clients must send X-API-Key header. Leave empty to
# disable auth (suitable for trusted local networks behind a reverse proxy).
# HARMONIE_API_KEY=

# Log level: DEBUG, INFO, WARNING, ERROR.
HARMONIE_LOG_LEVEL=INFO
